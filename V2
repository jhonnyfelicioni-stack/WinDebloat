    @{ Path="\Microsoft\Windows\Feedback\Siuf\";         Name="DmClient" },
    @{ Path="\Microsoft\Windows\Feedback\Siuf\";         Name="DmClientOnScenarioDownload" },
    @{ Path="\Microsoft\Windows\Windows Error Reporting\"; Name="QueueReporting" },
