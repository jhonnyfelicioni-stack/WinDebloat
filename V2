# ============================================================
#  FUNÇÃO DE REVERSÃO — executada com: .\WinOptimize-W11.ps1 -Reverter
#  Desfaz todas as alterações feitas pelo script principal.
# ============================================================
function Invoke-Reversao {

    Write-Host "`n"
    Write-Host "╔══════════════════════════════════════════════════════════╗" -ForegroundColor Yellow
    Write-Host "║        WinOptimize-W11 — MODO REVERSÃO                  ║" -ForegroundColor Yellow
    Write-Host "║  Restaurando configurações padrão do Windows...         ║" -ForegroundColor Yellow
    Write-Host "╚══════════════════════════════════════════════════════════╝" -ForegroundColor Yellow

    # --- Localiza o backup mais recente ---
    $backupBase = "$env:TEMP"
    $latestBackup = Get-ChildItem -Path $backupBase -Directory -Filter "WinOptimize_RegBackup_*" |
                    Sort-Object LastWriteTime -Descending | Select-Object -First 1
    if ($latestBackup) {
        Write-Host "`n  Backup encontrado: $($latestBackup.FullName)" -ForegroundColor Cyan
    } else {
        Write-WARN "Nenhum backup de registro encontrado em $backupBase. Continuando sem restaurar .reg..."
    }

    Write-Host ""
    $confirm = Read-Host "  Confirmar reversão completa? Isso restaura serviços, registro e hosts. (s/N)"
    if ($confirm -notmatch '^[sS]$') {
        Write-Host "  Reversão cancelada pelo usuário." -ForegroundColor Gray
        return
    }

    Write-Section "REVERSÃO 1/7 — Restaurar Registro (.reg)"
    if ($latestBackup) {
        $regFiles = Get-ChildItem -Path $latestBackup.FullName -Filter "*.reg" -ErrorAction SilentlyContinue
        foreach ($rf in $regFiles) {
            try {
                reg import $rf.FullName /y 2>$null | Out-Null
                Write-OK "Importado: $($rf.Name)"
            } catch { Write-ERR "Falha ao importar $($rf.Name): $_" }
        }
    } else {
        Write-SKIP "Sem arquivos .reg para importar."
    }

    Write-Section "REVERSÃO 2/7 — Reativar Serviços"

    $servicesToRestore = @(
        @{ Name="DiagTrack";        StartupType="Automatic" },  # Telemetria (volta ao padrão MS)
        @{ Name="dmwappushservice"; StartupType="Automatic" },
        @{ Name="SysMain";          StartupType="Automatic" },  # SuperFetch
        @{ Name="WSearch";          StartupType="Automatic" },  # Windows Search
        @{ Name="WerSvc";           StartupType="Manual"    },  # Error Reporting
        @{ Name="DPS";              StartupType="Automatic" },  # Diagnostic Policy
        @{ Name="PcaSvc";           StartupType="Automatic" },  # Program Compatibility
        @{ Name="WpnService";       StartupType="Automatic" },  # Push Notifications
        @{ Name="CDPSvc";           StartupType="Automatic" },  # Connected Devices
        @{ Name="MapsBroker";       StartupType="Automatic" },  # Maps
        @{ Name="lfsvc";            StartupType="Manual"    },  # Geolocation
        @{ Name="SensrSvc";         StartupType="Manual"    },  # Sensors
        @{ Name="RetailDemo";       StartupType="Disabled"  },  # Retail (mantém disabled)
        @{ Name="TabletInputService"; StartupType="Manual"  },
        @{ Name="DoSvc";            StartupType="Automatic" },  # Delivery Optimization
        @{ Name="WdiServiceHost";   StartupType="Manual"    },
        @{ Name="WdiSystemHost";    StartupType="Manual"    }
    )

    foreach ($svc in $servicesToRestore) {
        try {
            $s = Get-Service -Name $svc.Name -ErrorAction SilentlyContinue
            if ($null -eq $s) { Write-SKIP "Serviço não existe: $($svc.Name)"; continue }
            Set-Service -Name $svc.Name -StartupType $svc.StartupType -ErrorAction Stop
            if ($svc.StartupType -in @("Automatic","Manual")) {
                Start-Service -Name $svc.Name -ErrorAction SilentlyContinue
            }
            Write-OK "Serviço '$($svc.Name)' → $($svc.StartupType)"
        } catch { Write-ERR "Falha ao restaurar serviço '$($svc.Name)': $_" }
    }

    Write-Section "REVERSÃO 3/7 — Restaurar Registro (chaves individuais)"

    # Telemetria — remove bloqueios de política
    $polKeys = @(
        @{ P="HKLM:\SOFTWARE\Policies\Microsoft\Windows\DataCollection";             N="AllowTelemetry" },
        @{ P="HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\Policies\DataCollection"; N="AllowTelemetry" },
        @{ P="HKLM:\SOFTWARE\Policies\Microsoft\Windows\DataCollection";             N="LimitDiagnosticLogCollection" },
        @{ P="HKLM:\SOFTWARE\Policies\Microsoft\Windows\DataCollection";             N="DisableOneSettingsDownloads" },
        @{ P="HKLM:\SOFTWARE\Policies\Microsoft\SQMClient\Windows";                 N="CEIPEnable" },
        @{ P="HKLM:\SOFTWARE\Policies\Microsoft\Windows\Windows Error Reporting";   N="Disabled" },
        @{ P="HKLM:\SOFTWARE\Policies\Microsoft\Windows\AppCompat";                 N="AITEnable" },
        @{ P="HKLM:\SOFTWARE\Policies\Microsoft\Windows\AppCompat";                 N="DisableInventory" },
        @{ P="HKLM:\SOFTWARE\Policies\Microsoft\Windows\AppCompat";                 N="DisableUAR" },
        @{ P="HKLM:\SOFTWARE\Policies\Microsoft\Windows\DeliveryOptimization";      N="DODownloadMode" }
    )
    foreach ($k in $polKeys) { Remove-Reg -Path $k.P -Name $k.N }

    # Copilot e IA — remove desativações
    $aiKeys = @(
        @{ P="HKCU:\SOFTWARE\Policies\Microsoft\Windows\WindowsCopilot";  N="TurnOffWindowsCopilot" },
        @{ P="HKLM:\SOFTWARE\Policies\Microsoft\Windows\WindowsCopilot";  N="TurnOffWindowsCopilot" },
        @{ P="HKLM:\SOFTWARE\Policies\Microsoft\Windows\WindowsAI";       N="DisableAIDataAnalysis" },
        @{ P="HKCU:\SOFTWARE\Policies\Microsoft\Windows\WindowsAI";       N="DisableAIDataAnalysis" },
        @{ P="HKCU:\SOFTWARE\Microsoft\Windows\CurrentVersion\Explorer\Advanced"; N="ShowCopilotButton" },
        @{ P="HKLM:\SOFTWARE\Policies\Microsoft\Windows\Windows Search";  N="DisableWebSearch" },
        @{ P="HKLM:\SOFTWARE\Policies\Microsoft\Windows\Windows Search";  N="ConnectedSearchUseWeb" },
        @{ P="HKLM:\SOFTWARE\Policies\Microsoft\Windows\Windows Search";  N="AllowCloudSearch" },
        @{ P="HKLM:\SOFTWARE\Policies\Microsoft\Windows\Windows Search";  N="AllowCortana" }
    )
    foreach ($k in $aiKeys) { Remove-Reg -Path $k.P -Name $k.N }

    # Bing Search no Start
    try {
        Set-ItemProperty "HKCU:\SOFTWARE\Microsoft\Windows\CurrentVersion\Search" `
                         -Name "BingSearchEnabled" -Value 1 -Type DWord -Force -ErrorAction SilentlyContinue
        Write-OK "BingSearchEnabled restaurado para 1."
    } catch { Write-WARN "Não foi possível restaurar BingSearchEnabled." }

    # Widgets
    Remove-Reg -Path "HKLM:\SOFTWARE\Policies\Microsoft\Dsh" -Name "AllowNewsAndInterests"
    try {
        Set-ItemProperty "HKCU:\SOFTWARE\Microsoft\Windows\CurrentVersion\Explorer\Advanced" `
                         -Name "TaskbarDa" -Value 1 -Type DWord -Force -ErrorAction SilentlyContinue
        Write-OK "Widgets (TaskbarDa) restaurado."
    } catch {}

    # Hardware-Accelerated GPU Scheduling (volta ao padrão — 0)
    try {
        Set-ItemProperty "HKLM:\SYSTEM\CurrentControlSet\Control\GraphicsDrivers" `
                         -Name "HwSchMode" -Value 0 -Type DWord -Force -ErrorAction SilentlyContinue
        Write-OK "HAGS restaurado para padrão (0)."
    } catch {}

    # Mitigações Spectre/Meltdown (Modo Hardcore)
    Remove-Reg -Path "HKLM:\SYSTEM\CurrentControlSet\Control\Session Manager\Memory Management" `
               -Name "FeatureSettingsOverride"
    Remove-Reg -Path "HKLM:\SYSTEM\CurrentControlSet\Control\Session Manager\Memory Management" `
               -Name "FeatureSettingsOverrideMask"

    # Memory Management — LargeSystemCache e DisablePagingExecutive ao padrão
    try {
        Set-ItemProperty "HKLM:\SYSTEM\CurrentControlSet\Control\Session Manager\Memory Management" `
                         -Name "LargeSystemCache" -Value 0 -Type DWord -Force -ErrorAction SilentlyContinue
        Set-ItemProperty "HKLM:\SYSTEM\CurrentControlSet\Control\Session Manager\Memory Management" `
                         -Name "DisablePagingExecutive" -Value 0 -Type DWord -Force -ErrorAction SilentlyContinue
        Write-OK "Memory Management restaurado para padrões."
    } catch {}

    # ContentDelivery (sugestões no Start)
    $cdmKeys = @("SystemPaneSuggestionsEnabled","SubscribedContent-338388Enabled",
                 "SubscribedContent-338389Enabled","SilentInstalledAppsEnabled",
                 "ContentDeliveryAllowed","OemPreInstalledAppsEnabled")
    foreach ($k in $cdmKeys) {
        try {
            Set-ItemProperty "HKCU:\SOFTWARE\Microsoft\Windows\CurrentVersion\ContentDeliveryManager" `
                             -Name $k -Value 1 -Type DWord -Force -ErrorAction SilentlyContinue
        } catch {}
    }
    Write-OK "ContentDeliveryManager (sugestões Start) restaurado."

    Write-Section "REVERSÃO 4/7 — Reativar Tarefas Agendadas"

    $tasksToRestore = @(
        @{ P="\Microsoft\Windows\Application Experience\"; N="Microsoft Compatibility Appraiser" },
        @{ P="\Microsoft\Windows\Application Experience\"; N="ProgramDataUpdater" },
        @{ P="\Microsoft\Windows\Customer Experience Improvement Program\"; N="Consolidator" },
        @{ P="\Microsoft\Windows\Customer Experience Improvement Program\"; N="UsbCeip" },
        @{ P="\Microsoft\Windows\Feedback\Siuf\";           N="DmClient" },
        @{ P="\Microsoft\Windows\Windows Error Reporting\"; N="QueueReporting" },
        @{ P="\Microsoft\Windows\Maps\";                    N="MapsUpdateTask" }
    )
    foreach ($t in $tasksToRestore) {
        try {
            $task = Get-ScheduledTask -TaskPath $t.P -TaskName $t.N -ErrorAction SilentlyContinue
            if ($task) {
                Enable-ScheduledTask -TaskPath $t.P -TaskName $t.N -ErrorAction Stop | Out-Null
                Write-OK "Tarefa reativada: $($t.P)$($t.N)"
            } else { Write-SKIP "Tarefa não encontrada: $($t.P)$($t.N)" }
        } catch { Write-ERR "Falha ao reativar tarefa: $($t.P)$($t.N) — $_" }
    }

    Write-Section "REVERSÃO 5/7 — Restaurar Plano de Energia"

    try {
        # Volta para o plano Balanced (padrão do Windows)
        powercfg -setactive 381b4222-f694-41f0-9685-ff5bb260df2e | Out-Null
        Write-OK "Plano de energia restaurado para: Balanced (padrão)."
    } catch { Write-ERR "Falha ao restaurar plano de energia: $_" }

    Write-Section "REVERSÃO 6/7 — Restaurar HPET e BCD (se Modo Hardcore foi usado)"

    try {
        bcdedit /deletevalue useplatformclock  2>$null | Out-Null
        bcdedit /deletevalue disabledynamictick 2>$null | Out-Null
        Write-OK "BCD: useplatformclock e disabledynamictick removidos."
    } catch { Write-WARN "Falha ao restaurar BCD (pode não ter sido alterado): $_" }

    Write-Section "REVERSÃO 7/7 — Restaurar Hosts"

    $hostsPath   = "$env:SystemRoot\System32\drivers\etc\hosts"
    $hostsBackup = $null
    if ($latestBackup) {
        $hostsBackup = Join-Path $latestBackup.FullName "hosts.bak"
    }

    if ($hostsBackup -and (Test-Path $hostsBackup)) {
        try {
            Copy-Item -Path $hostsBackup -Destination $hostsPath -Force -ErrorAction Stop
            Write-OK "Arquivo hosts restaurado do backup."
        } catch { Write-ERR "Falha ao restaurar hosts: $_" }
    } else {
        # Sem backup — remove apenas as entradas adicionadas pelo script
        try {
            $hostsContent = Get-Content -Path $hostsPath -ErrorAction Stop
            $cleaned = $hostsContent | Where-Object {
                $_ -notmatch "WinOptimize" -and
                $_ -notmatch "^0\.0\.0\.0\s+(vortex|telecommand|watson|sqm|oca|choice|df\.telemetry|reports\.|wes\.|survey\.|statsfe|feedback\.|rad\.msn|ads\.msn|copilot\.microsoft|sydney\.bing|edgeservices\.bing|bingapis)"
            }
            Set-Content -Path $hostsPath -Value $cleaned -Encoding UTF8 -Force
            Write-OK "Entradas de telemetria removidas do hosts (sem backup disponível)."
        } catch { Write-ERR "Falha ao limpar hosts: $_" }
    }

    # --- Reinicia Explorer para aplicar reversão de UI ---
    try {
        Stop-Process -Name "explorer" -Force -ErrorAction SilentlyContinue
        Start-Sleep 2
        Start-Process "explorer.exe"
        Write-OK "Explorer reiniciado."
    } catch {}

    # --- Resumo da reversão ---
    Write-Host "`n"
    Write-Host "╔══════════════════════════════════════════════════════════╗" -ForegroundColor Green
    Write-Host "║            REVERSÃO CONCLUÍDA                           ║" -ForegroundColor Green
    Write-Host "╚══════════════════════════════════════════════════════════╝" -ForegroundColor Green
    Write-Host ""
    Write-Host "  O sistema foi restaurado ao estado anterior." -ForegroundColor White
    Write-Host "  Apps removidos (bloatware) precisam ser reinstalados" -ForegroundColor Yellow
    Write-Host "  manualmente pela Microsoft Store." -ForegroundColor Yellow
    Write-Host ""
    Write-Host "  REINICIE o computador para garantir que todas as" -ForegroundColor Yellow
    Write-Host "  mudanças de serviços e registro sejam aplicadas." -ForegroundColor Yellow

    $rb = Read-Host "`n  Reiniciar agora? (s/N)"
    if ($rb -match '^[sS]$') {
        Start-Sleep 3
        Restart-Computer -Force
    }
}

# ============================================================
#  PONTO DE ENTRADA: -Reverter desvia para a função de reversão
# ============================================================
if ($Reverter) {
    # Garante que as funções auxiliares existam mesmo no modo reversão
    # (Write-Log, Write-Section, etc. já foram definidas acima)
    $LogFile   = "$env:TEMP\WinOptimize_Reverter_$(Get-Date -Format 'yyyyMMdd-HHmm').log"
    New-Item -Path $LogFile -ItemType File -Force | Out-Null

    # Precisa das funções Remove-Reg — define aqui se não existir
    if (-not (Get-Command Remove-Reg -ErrorAction SilentlyContinue)) {
        function Remove-Reg {
            param([string]$Path, [string]$Name)
            try {
                if (Get-ItemProperty -Path $Path -Name $Name -ErrorAction SilentlyContinue) {
                    Remove-ItemProperty -Path $Path -Name $Name -Force -ErrorAction Stop
                    Write-OK "Removido: $Path\$Name"
                } else { Write-SKIP "Já inexistente: $Path\$Name" }
            } catch { Write-ERR "Falha ao remover $Path\$Name — $_" }
        }
    }

    Invoke-Reversao
    exit 0
}
