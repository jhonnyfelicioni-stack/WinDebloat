    @{ Path="\Microsoft\Windows\Application Experience\"; Name="ProgramDataUpdater" },
    @{ Path="\Microsoft\Windows\Application Experience\"; Name="StartupAppTask" },
    @{ Path="\Microsoft\Windows\Autochk\";               Name="Proxy" },
